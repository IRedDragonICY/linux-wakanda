From: Wakanda Kernel <wakanda@localhost>
Date: Tue, 25 Mar 2026 15:53:00 +0700
Subject: [PATCH] platform/x86: msi-ec: Add MSI Bravo 15 C7VE (MS-158N)
 support

Add CONF14 hardware profile for the MSI Bravo 15 C7VE laptop (board
MS-158N, EC firmware prefix 158NIMS). The EC register map was obtained
through direct I/O port probing (0x62/0x66).

Supported features:
  - Battery charge control (0xD7)
  - Shift mode / platform profiles: Sport, Balanced, Eco, Turbo (0xD2)
  - Fan mode: Auto, Silent, Basic, Advanced (0xD4)
  - Cooler Boost toggle (0x98)
  - CPU temperature and fan speed (0x68/0x71)
  - dGPU temperature and fan speed (0x80/0x89)
  - Webcam status/block (0x2E/0x2F)
  - Keyboard backlight state (0xD3)
  - Fn-Win swap (0xE8)
  - Mic-mute and mute LEDs (0x2B/0x2C)

Also extend the firmware matching logic in load_configuration() with
prefix-based matching via strstarts(), since the EC firmware string
"158NIMS1.10E" does not appear in any existing allowed firmware list
and the 7-character prefix "158NIMS" is sufficient for identification.

Signed-off-by: Wakanda Kernel <wakanda@localhost>
---
 drivers/platform/x86/msi-ec.c | 87 ++++++++++++++++++++++++++++++++++
 1 file changed, 87 insertions(+)

diff --git a/drivers/platform/x86/msi-ec.c b/drivers/platform/x86/msi-ec.c
--- a/drivers/platform/x86/msi-ec.c
+++ b/drivers/platform/x86/msi-ec.c
@@ -1056,6 +1056,11 @@
 	NULL
 };
 
+static const char * const ALLOWED_FW_14[] __initconst = {
+	"158NIMS", // MSI Bravo 15 C7VE (Wakanda Custom Extreme)
+	NULL
+};
+
 static struct msi_ec_conf CONF13 __initdata = {
 	.allowed_fw = ALLOWED_FW_13,
 	.charge_control = {
@@ -1128,6 +1133,78 @@
 	},
 };
 
+static struct msi_ec_conf CONF14 __initdata = {
+	.allowed_fw = ALLOWED_FW_14,
+	.charge_control = {
+		.address      = 0xd7,
+		.offset_start = 0x8a,
+		.offset_end   = 0x80,
+		.range_min    = 0x8a,
+		.range_max    = 0xe4,
+	},
+	.webcam = {
+		.address       = 0x2e,
+		.block_address = 0x2f,
+		.bit           = 1,
+	},
+	.fn_win_swap = {
+		.address = 0xe8,
+		.bit     = 4,
+	},
+	.cooler_boost = {
+		.address = 0x98,
+		.bit     = 7,
+	},
+	.shift_mode = {
+		.address = 0xd2,
+		.modes = {
+			{ SM_ECO_NAME,     0xc2 },
+			{ SM_COMFORT_NAME, 0xc1 },
+			{ SM_SPORT_NAME,   0xc0 },
+			{ SM_TURBO_NAME,   0xc4 },
+			MSI_EC_MODE_NULL
+		},
+	},
+	.super_battery = {
+		.address = MSI_EC_ADDR_UNSUPP,
+		.mask    = 0x0f,
+	},
+	.fan_mode = {
+		.address = 0xd4,
+		.modes = {
+			{ FM_AUTO_NAME,     0x0d },
+			{ FM_SILENT_NAME,   0x1d },
+			{ FM_BASIC_NAME,    0x4d },
+			{ FM_ADVANCED_NAME, 0x8d },
+			MSI_EC_MODE_NULL
+		},
+	},
+	.cpu = {
+		.rt_temp_address       = 0x68,
+		.rt_fan_speed_address  = 0x71,
+		.rt_fan_speed_base_min = 0x19,
+		.rt_fan_speed_base_max = 0x37,
+		.bs_fan_speed_address  = MSI_EC_ADDR_UNSUPP,
+	},
+	.gpu = {
+		.rt_temp_address      = 0x80,
+		.rt_fan_speed_address = 0x89,
+	},
+	.leds = {
+		.micmute_led_address = 0x2b,
+		.mute_led_address    = 0x2c,
+		.bit                 = 1,
+	},
+	.kbd_bl = {
+		.bl_mode_address  = MSI_EC_ADDR_UNKNOWN,
+		.bl_modes         = { 0x00, 0x08 },
+		.max_mode         = 1,
+		.bl_state_address = 0xd3,
+		.state_base_value = 0x80,
+		.max_state        = 3,
+	},
+};
+
 static struct msi_ec_conf *CONFIGS[] __initdata = {
 	&CONF0,
 	&CONF1,
@@ -1143,6 +1220,7 @@
 	&CONF11,
 	&CONF12,
 	&CONF13,
+	&CONF14,
 	NULL
 };
 
@@ -1316,11 +1394,21 @@
 
 	/* load the suitable configuration, if exists */
 	for (int i = 0; CONFIGS[i]; i++) {
+		/* Original strict matching */
 		if (match_string(CONFIGS[i]->allowed_fw, -1, fw_version) != -EINVAL) {
 			conf = *CONFIGS[i];
 			conf.allowed_fw = NULL;
 			return 0;
 		}
+
+		/* Wakanda Prefix Matching Patch */
+		for (int j = 0; CONFIGS[i]->allowed_fw[j]; j++) {
+			if (strstarts(fw_version, CONFIGS[i]->allowed_fw[j])) {
+				conf = *CONFIGS[i];
+				conf.allowed_fw = NULL;
+				return 0;
+			}
+		}
 	}
 
 	/* config not found */
-- 
2.47.1
